# Afrimercato Frontend Environment Variables
# Copy this to .env and fill in your values

# API Configuration
# IMPORTANT: Do NOT include /api suffix - it's added automatically in code
# For local development
# VITE_API_URL=http://localhost:5000

# For production (update with your actual backend URL)
VITE_API_URL=https://afrimercato-backend-1.onrender.com
# VITE_API_URL=https://afrimercato-backend-1.onrender.com

# Beta Launch Configuration
VITE_FEEDBACK_URL=https://forms.gle/YOUR_GOOGLE_FORM_ID
VITE_LAUNCH_DAYS=7
# VITE_LAUNCH_DATE=2026-02-12T00:00:00Z  # Optional: specific launch date
VITE_APP_VERSION=beta-1.0

# Stripe (Test Mode)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Google OAuth (Optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_RECIPES=true
VITE_ENABLE_WISHLIST=true
VITE_MULTI_VENDOR_CART=true

# Push Notifications (Web Push / VAPID)
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Crisp Live Chat (optional — get Website ID from crisp.chat dashboard)
VITE_CRISP_WEBSITE_ID=your_crisp_website_id_here

# Stream Chat (in-app order chat: customer ↔ vendor ↔ rider)
# Get your API key from getstream.io dashboard
# Backend also needs: STREAM_API_KEY + STREAM_API_SECRET (set via Fly.io secrets)
VITE_STREAM_API_KEY=your_stream_api_key_here

